# grodex — run OpenAI's GPT-5.6 models (Sol / Terra / Luna) on your ChatGPT/Codex
# subscription through the grok CLI.
#
# Generated by install.sh. Placeholders (__GRODEX_HOME__, __PORT__, __ACCOUNT_ID__)
# are filled in at install time. Safe to edit afterward.
#
# In the TUI: press Ctrl+M to switch model (Sol / Terra / Luna), and use grok's
# reasoning-effort control to switch effort (low / medium / high / xhigh).

[auth]
# External auth provider: bridges your `codex login` session in as grok's bearer.
auth_provider_command = "__GRODEX_HOME__/codex-auth.sh"
auth_provider_label = "ChatGPT (Codex)"

[models]
default = "gpt-5.6-sol"
default_reasoning_effort = "high"

# --- GPT-5.6 Sol (default) -------------------------------------------------
[model."gpt-5.6-sol"]
model = "gpt-5.6-sol"
name = "GPT-5.6 Sol (ChatGPT)"
base_url = "http://127.0.0.1:__PORT__"
api_backend = "responses"
context_window = 272000            # ChatGPT/Codex subscription cap (API tier is larger)
stream_tool_calls = false          # ChatGPT backend rejects grok's xAI-only body field
supports_reasoning_effort = true   # the responses backend doesn't auto-enable this
reasoning_efforts = ["low", "medium", "high", "xhigh"]  # minimal is not accepted
reasoning_effort = "high"
extra_headers = { "chatgpt-account-id" = "__ACCOUNT_ID__", "OpenAI-Beta" = "responses=experimental", "originator" = "codex_cli_rs", "User-Agent" = "codex_cli_rs/0.144.4" }

# --- GPT-5.6 Terra ---------------------------------------------------------
[model."gpt-5.6-terra"]
model = "gpt-5.6-terra"
name = "GPT-5.6 Terra (ChatGPT)"
base_url = "http://127.0.0.1:__PORT__"
api_backend = "responses"
context_window = 272000
stream_tool_calls = false
supports_reasoning_effort = true
reasoning_efforts = ["low", "medium", "high", "xhigh"]
reasoning_effort = "high"
extra_headers = { "chatgpt-account-id" = "__ACCOUNT_ID__", "OpenAI-Beta" = "responses=experimental", "originator" = "codex_cli_rs", "User-Agent" = "codex_cli_rs/0.144.4" }

# --- GPT-5.6 Luna ----------------------------------------------------------
[model."gpt-5.6-luna"]
model = "gpt-5.6-luna"
name = "GPT-5.6 Luna (ChatGPT)"
base_url = "http://127.0.0.1:__PORT__"
api_backend = "responses"
context_window = 272000
stream_tool_calls = false
supports_reasoning_effort = true
reasoning_efforts = ["low", "medium", "high", "xhigh"]
reasoning_effort = "high"
extra_headers = { "chatgpt-account-id" = "__ACCOUNT_ID__", "OpenAI-Beta" = "responses=experimental", "originator" = "codex_cli_rs", "User-Agent" = "codex_cli_rs/0.144.4" }

[features]
telemetry = false

[cli]
auto_update = false
